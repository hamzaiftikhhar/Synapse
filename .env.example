# PostgreSQL 18 + pgvector (Homebrew / local)
# Copy to .env and adjust for your local Postgres.

DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,[::1]

POSTGRES_DB=synapse
POSTGRES_USER=synapse
POSTGRES_PASSWORD=synapse
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
CONN_MAX_AGE=60

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://127.0.0.1:8000

# Staff JWT (portal)
# JWT_SECRET_KEY=  # defaults to SECRET_KEY
JWT_STAFF_ACCESS_TOKEN_EXPIRE_MINUTES=480
JWT_STAFF_REFRESH_TOKEN_EXPIRE_DAYS=14

# Patient JWT (widget OTP)
JWT_PATIENT_ACCESS_TOKEN_EXPIRE_MINUTES=120
OTP_EXPIRE_MINUTES=10
OTP_CODE_LENGTH=6

# Twilio (optional in local — OTP is logged / returned as debug_code when unset)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# Production-only (ignored in development)
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=31536000
